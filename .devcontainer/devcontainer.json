{
  "name": "Antenna",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "target": "base"
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    "source=claude-config,target=/root/.claude,type=volume"
  ],
  "postCreateCommand": "uv sync && if [ -f /root/.claude/.claude.json ] && [ ! -f /root/.claude.json ]; then ln -s /root/.claude/.claude.json /root/.claude.json; fi && curl -fsSL https://claude.ai/install.sh | bash",
  "containerEnv": {
    "FCC_API_SPATIALITE_PATH": "mod_spatialite"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "charliermarsh.ruff",
        "ms-python.python"
      ],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "forwardPorts": [8000]
}
